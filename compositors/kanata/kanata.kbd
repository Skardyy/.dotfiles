;; ln -sf ~/.dotfiles/compositors/kanata/kanata.kbd ~/.config/kanata.kbd

(defcfg
  process-unmapped-keys yes
)

(defsrc
  caps lalt
  i    j    k    l
)

(deflayer default
  esc  @alt_nav
  i    j    k    l
)

(deflayer navigation
  _    _
  up   left down rght
)

(defalias
  ;; Tap: Alt | Hold: Navigation Layer
  alt_nav (tap-hold 200 200 lalt (layer-toggle navigation))
)
