;; ln -sf ~/.dotfiles/compositors/kanata/kanata.kbd ~/.config/kanata.kbd

(defcfg
  process-unmapped-keys yes
)

(defsrc
  caps lalt
  i    o    p
  h    j    k    l
)

(deflayer default
  esc  @alt_nav
  i    o    p
  h    j    k    l
)

(deflayer navigation
  _    _
  -    =    bspc
  left down up   rght
)

(defalias
  alt_nav (layer-while-held navigation)
)
