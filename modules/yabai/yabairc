#!/usr/bin/env sh

# === Layout ===
yabai -m config layout                      bsp
yabai -m config window_placement            second_child
yabai -m config window_origin_display       focused
yabai -m config split_ratio                 0.50
yabai -m config auto_balance                off

# === Gaps (mirrors aerospace) ===
yabai -m config top_padding                 4
yabai -m config bottom_padding              4
yabai -m config left_padding                4
yabai -m config right_padding               4
yabai -m config window_gap                  12

# === Mouse (mango-style mod+drag) ===
yabai -m config mouse_modifier              cmd
yabai -m config mouse_action1               move
yabai -m config mouse_action2               resize
yabai -m config mouse_drop_action           swap

# === Mouse-follows-focus (cursor jumps to focused window on keybind) ===
yabai -m config mouse_follows_focus         on

# === Float rules for common dialogs/system apps ===
yabai -m rule --add app="^System Settings$"        manage=off
yabai -m rule --add app="^System Information$"     manage=off
yabai -m rule --add app="^Finder$" title="Copy"    manage=off
yabai -m rule --add app="^Finder$" title="Move"    manage=off
yabai -m rule --add app="^Raycast$"                manage=off
yabai -m rule --add app="^Calculator$"             manage=off
yabai -m rule --add app="^Archive Utility$"        manage=off

echo "yabai configuration loaded.."
