#!/usr/bin/env sh

# === Layout ===
yabai -m config layout                      bsp
yabai -m config window_placement            second_child
yabai -m config window_origin_display       focused
yabai -m config split_ratio                 0.50
yabai -m config auto_balance                off

# === Gaps (mirrors aerospace) ===
yabai -m config top_padding                 4
yabai -m config bottom_padding              4
yabai -m config left_padding                4
yabai -m config right_padding               4
yabai -m config window_gap                  12

# === Mouse (mango-style mod+drag) ===
yabai -m config mouse_modifier              cmd
yabai -m config mouse_action1               move
yabai -m config mouse_action2               resize
yabai -m config mouse_drop_action           swap

# === Mouse-follows-focus (cursor jumps to focused window on keybind) ===
yabai -m config mouse_follows_focus         on

# === Float rules for common dialogs/system apps ===
yabai -m rule --add app="^System Settings$"        manage=off
yabai -m rule --add app="^System Information$"     manage=off
yabai -m rule --add app="^System Preferences$"     manage=off
yabai -m rule --add app="^Finder$" title="Copy"    manage=off
yabai -m rule --add app="^Finder$" title="Move"    manage=off
yabai -m rule --add app="^Finder$" subrole="AXDialog" manage=off
yabai -m rule --add app="^Raycast$"                manage=off
yabai -m rule --add app="^Calculator$"             manage=off
yabai -m rule --add app="^Archive Utility$"        manage=off

# Permission / authentication / system popups
yabai -m rule --add app="^Installer$"              manage=off
yabai -m rule --add app="^Software Update$"        manage=off
yabai -m rule --add app="^UserNotificationCenter$" manage=off
yabai -m rule --add app="^SecurityAgent$"          manage=off
yabai -m rule --add app="^Security & Privacy$"     manage=off
yabai -m rule --add app="^Bluetooth File Exchange$" manage=off
yabai -m rule --add app="^Stickies$"               manage=off
yabai -m rule --add app="^Photo Booth$"            manage=off
yabai -m rule --add app="^ColorSync Utility$"      manage=off
yabai -m rule --add app="^Disk Utility$"           manage=off
yabai -m rule --add app="^Activity Monitor$"       manage=off
yabai -m rule --add app="^Console$"                manage=off
yabai -m rule --add app="^Keychain Access$"        manage=off
yabai -m rule --add app="^Font Book$"              manage=off
yabai -m rule --add app="^Migration Assistant$"    manage=off

# Any AXDialog/AXSheet — catches most "Allow access?" style popups
yabai -m rule --add subrole="AXDialog"             manage=off
yabai -m rule --add subrole="AXSystemDialog"       manage=off
yabai -m rule --add subrole="AXFloatingWindow"     manage=off

echo "yabai configuration loaded.."
